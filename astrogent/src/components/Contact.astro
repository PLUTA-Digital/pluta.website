---
import { Icon } from 'astro-icon/components';
---

<section id="contact" class="bg-mono-lighter px-4 py-20 sm:px-6 lg:px-8">
  <div class="mx-auto max-w-7xl">
    <div class="grid grid-cols-1 items-start gap-12 lg:grid-cols-2">
      <div class="scroll-fade-left">
        <h2 class="text-mono-black mb-6 text-4xl font-bold sm:text-5xl">
          Starten Sie noch heute
        </h2>
        <p class="text-mono-dark mb-8 text-xl leading-relaxed">
          Ersetzen Sie fehleranfällige Excel-Modelle durch professionelle Liquiditätsplanung. Einsatzbereit innerhalb eines Tages.
        </p>

        <ul class="mb-8 space-y-4">
          <li class="flex items-center">
            <Icon
              name="heroicons:check"
              class="text-mono-black mr-4 h-6 w-6 flex-shrink-0"
            />
            <span class="text-mono-dark">Lokale Installation – Ihre Daten bleiben bei Ihnen</span>
          </li>
          <li class="flex items-center">
            <Icon
              name="heroicons:check"
              class="text-mono-black mr-4 h-6 w-6 flex-shrink-0"
            />
            <span class="text-mono-dark">Schnelle Implementierung – einsatzfähig innerhalb eines Tages</span>
          </li>
          <li class="flex items-center">
            <Icon
              name="heroicons:check"
              class="text-mono-black mr-4 h-6 w-6 flex-shrink-0"
            />
            <span class="text-mono-dark">Individuelle Anpassungen möglich</span>
          </li>
          <li class="flex items-center">
            <Icon
              name="heroicons:check"
              class="text-mono-black mr-4 h-6 w-6 flex-shrink-0"
            />
            <span class="text-mono-dark">Kontinuierliche Weiterentwicklung durch planungserfahrene Berater</span>
          </li>
        </ul>

        <div class="border-mono-light border-t pt-8">
          <p class="text-mono-gray mb-4 text-sm">
            Fragen? Kontaktieren Sie unser Team:
          </p>
          <a
            href="mailto:liquitool@pluta.net"
            class="text-mono-black font-semibold">liquitool@pluta.net</a
          >
        </div>
      </div>

      <div
        class="scroll-fade-right border-mono-lighter rounded-xl border bg-white p-8 shadow-lg"
      >
        <form id="contactForm" class="space-y-6">
          <div>
            <label
              for="name"
              class="text-mono-black mb-2 block text-sm font-semibold"
              >Name</label
            >
            <input
              type="text"
              id="name"
              name="name"
              required
              class="border-mono-lighter w-full rounded-lg border px-4 py-3"
              placeholder="Max Mustermann"
            />
          </div>

          <div>
            <label
              for="email"
              class="text-mono-black mb-2 block text-sm font-semibold"
              >E-Mail-Adresse</label
            >
            <input
              type="email"
              id="email"
              name="email"
              required
              class="border-mono-lighter w-full rounded-lg border px-4 py-3"
              placeholder="max.mustermann@unternehmen.de"
            />
          </div>

          <div>
            <label
              for="company"
              class="text-mono-black mb-2 block text-sm font-semibold"
              >Unternehmen</label
            >
            <input
              type="text"
              id="company"
              name="company"
              class="border-mono-lighter w-full rounded-lg border px-4 py-3"
              placeholder="Ihr Unternehmen"
            />
          </div>

          <div>
            <label
              for="message"
              class="text-mono-black mb-2 block text-sm font-semibold"
              >Nachricht</label
            >
            <textarea
              id="message"
              name="message"
              rows="4"
              class="form-input border-mono-lighter w-full resize-none rounded-lg border px-4 py-3"
              placeholder="Erzählen Sie uns von Ihren Anforderungen an die Liquiditätsplanung..."
            ></textarea>
          </div>

          <button
            type="submit"
            class="bg-mono-black w-full rounded-lg px-6 py-4 font-semibold text-white shadow-lg"
          >
            Anfrage senden
          </button>

          <p class="text-mono-gray text-center text-xs leading-relaxed">
            Mit dem Absenden dieses Formulars stimmen Sie unseren
            <a href="#" class="underline">Nutzungsbedingungen</a> und der
            <a href="#" class="underline">Datenschutzerklärung</a> zu.
          </p>
        </form>
      </div>
    </div>
  </div>
</section>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const contactForm = document.getElementById('contactForm') as HTMLFormElement;
    if (contactForm) {
      contactForm.addEventListener('submit', (e) => {
        e.preventDefault();
        alert('Vielen Dank für Ihre Nachricht! Wir werden uns bald bei Ihnen melden.');
        contactForm.reset();
      });
    }
  });
</script>
