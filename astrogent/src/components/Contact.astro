---
import { Icon } from 'astro-icon/components';
---

<section id="contact" class="bg-mono-lighter px-4 py-20 sm:px-6 lg:px-8">
  <div class="mx-auto max-w-7xl">
    <div class="grid grid-cols-1 items-start gap-12 lg:grid-cols-2">
      <div class="scroll-fade-left">
        <h2 class="text-mono-black mb-6 text-4xl font-bold sm:text-5xl">
          Starten Sie noch heute
        </h2>
        <p class="text-mono-dark mb-8 text-xl leading-relaxed">
          Haben Sie Fragen zum PLUTA LiquiTool oder benötigen Sie eine individuelle Beratung? Unsere Berater stehen Ihnen gerne zur Verfügung.
        </p>

        <div class="space-y-6">
          <!-- Visitenkarte 1: Simon Eickmann -->
          <div class="border-mono-lighter rounded-xl border bg-white p-6 shadow-md">
            <div class="flex gap-4">
              <div class="flex-shrink-0">
                <img
                  src="/contact/simon.jpg"
                  alt="Simon Eickmann"
                  class="h-20 w-20 rounded-full object-cover"
                />
              </div>
              <div class="flex-1">
                <div class="text-mono-black mb-1 text-lg font-bold">
                  Simon Eickmann
                </div>
                <div class="text-mono-dark mb-2 text-sm">
                  Geschäftsführer
                </div>
                <div class="text-mono-black mb-2 text-sm font-semibold">
                  PLUTA Digital GmbH
                </div>
                <div class="text-mono-dark mb-2 text-sm">
                  Radlkoferstraße 2 - 81373 München
                </div>
                <div class="text-mono-dark mb-1 text-sm">
                  Telefon: +49 89 24413337-0
                </div>
                <a
                  href="mailto:simon.eickmann@pluta.net"
                  class="text-mono-black text-sm font-semibold hover:underline"
                >
                  simon.eickmann@pluta.net
                </a>
              </div>
            </div>
          </div>

          <!-- Visitenkarte 2: Heinz-Joachim Hombach -->
          <div class="border-mono-lighter rounded-xl border bg-white p-6 shadow-md">
            <div class="flex gap-4">
              <div class="flex-shrink-0">
                <img
                  src="/contact/hj.jpg"
                  alt="Heinz-Joachim Hombach"
                  class="h-20 w-20 rounded-full object-cover"
                />
              </div>
              <div class="flex-1">
                <div class="text-mono-black mb-1 text-lg font-bold">
                  Heinz-Joachim Hombach
                </div>
                <div class="text-mono-dark mb-2 text-sm">
                  Geschäftsführer
                </div>
                <div class="text-mono-black mb-2 text-sm font-semibold">
                  PLUTA Digital GmbH
                </div>
                <div class="text-mono-dark mb-2 text-sm">
                  Radlkoferstraße 2 - 81373 München
                </div>
                <div class="text-mono-dark mb-1 text-sm">
                  Telefon: +49 89 24413337-0
                </div>
                <a
                  href="mailto:heinz-joachim.hombach@pluta.net"
                  class="text-mono-black text-sm font-semibold hover:underline"
                >
                  heinz-joachim.hombach@pluta.net
                </a>
              </div>
            </div>
          </div>
        </div>
      </div>

      <div
        class="scroll-fade-right border-mono-lighter rounded-xl border bg-white p-8 shadow-lg"
      >
        <form 
          id="contactForm" 
          name="contact"
          method="POST"
          data-netlify="true"
          action="/form-success"
          netlify-honeypot="bot-field"
          class="space-y-6"
        >
          <input type="hidden" name="form-name" value="contact" />
          <div style="display: none;">
            <label>
              Nicht ausfüllen, wenn Sie ein Mensch sind: <input name="bot-field" />
            </label>
          </div>

          <div>
            <label
              for="name"
              class="text-mono-black mb-2 block text-sm font-semibold"
              >Name</label
            >
            <input
              type="text"
              id="name"
              name="name"              
              required
              class="border-mono-lighter w-full rounded-lg border px-4 py-3"
              placeholder="Max Mustermann"
            />
          </div>

          <div>
            <label
              for="email"
              class="text-mono-black mb-2 block text-sm font-semibold"
              >E-Mail-Adresse</label
            >
            <input
              type="email"
              id="email"
              name="email"
              required
              class="border-mono-lighter w-full rounded-lg border px-4 py-3"
              placeholder="max.mustermann@unternehmen.de"
            />
          </div>

          <div>
            <label
              for="company"
              class="text-mono-black mb-2 block text-sm font-semibold"
              >Unternehmen</label
            >
            <input
              type="text"
              id="company"
              name="company"
              class="border-mono-lighter w-full rounded-lg border px-4 py-3"
              placeholder="Ihr Unternehmen"
            />
          </div>

          <div>
            <label
              for="message"
              class="text-mono-black mb-2 block text-sm font-semibold"
              >Nachricht</label
            >
            <textarea
              id="message"
              name="message"
              rows="4"
              class="form-input border-mono-lighter w-full resize-none rounded-lg border px-4 py-3"
              placeholder="Erzählen Sie uns von Ihren Anforderungen an die Liquiditätsplanung..."
            ></textarea>
          </div>

          <button
            type="submit"
            class="bg-mono-black w-full rounded-lg px-6 py-4 font-semibold text-white shadow-lg"
          >
            Anfrage senden
          </button>

          <p class="text-mono-gray text-center text-xs leading-relaxed">
            Mit dem Absenden dieses Formulars stimmen Sie unseren
            <a href="/impressum#nutzungsbedingungen" class="underline">Nutzungsbedingungen</a> und der
            <a href="/impressum#datenschutz" class="underline">Datenschutzerklärung</a> zu.
          </p>
        </form>
      </div>
    </div>
  </div>
</section>
