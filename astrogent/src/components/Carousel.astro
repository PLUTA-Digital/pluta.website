---
import '@glidejs/glide/dist/css/glide.core.min.css';
import '@glidejs/glide/dist/css/glide.theme.min.css';

// Screenshots - erweitere diese Liste bei Bedarf
const screenshots = ['screen1.jpg', 'screen2.jpg'];
---

<section class="bg-white px-4 py-16 sm:px-6 lg:px-8">
  <div class="mx-auto max-w-7xl">
    <div class="glide">
      <div class="glide__track" data-glide-el="track">
        <ul class="glide__slides">
          {screenshots.map((screenshot, index) => (
            <li class="glide__slide">
              <div class="flex items-center justify-center">
                <img
                  src={`/screenshots/${screenshot}`}
                  alt={`Screenshot ${index + 1}: PLUTA LiquiTool`}
                  loading="lazy"
                  class="max-h-[600px] w-auto rounded-lg shadow-xl"
                />
              </div>
            </li>
          ))}
        </ul>
      </div>

      <div class="glide__arrows" data-glide-el="controls">
        <button class="glide__arrow glide__arrow--left" data-glide-dir="<">
          ‹
        </button>
        <button class="glide__arrow glide__arrow--right" data-glide-dir=">">
          ›
        </button>
      </div>

      <div class="glide__bullets" data-glide-el="controls[nav]">
        {screenshots.map((_, index) => (
          <button class="glide__bullet" data-glide-dir={`=${index}`}></button>
        ))}
      </div>
    </div>
  </div>
</section>

<script>
  import Glide from '@glidejs/glide';

  new Glide('.glide', {
    type: 'carousel',
    autoplay: 5000,
    hoverpause: true,
    rewind: true,
  }).mount();
</script>

<style>
  .glide__arrow {
    background: #3C5990; /* PLUTA Blau 600 */
    color: #fff;
    border: none;
    border-radius: 50%;
    width: 48px;
    height: 48px;
    font-size: 1.5rem;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.2s;
  }

  .glide__arrow:hover {
    background: #283C60; /* PLUTA Blau 700 */
  }

  .glide__arrow--left {
    left: 1.5rem;
  }

  .glide__arrow--right {
    right: 1.5rem;
  }

  .glide__bullets {
    gap: 0.75rem;
    margin-top: 2rem;
  }

  .glide__bullet {
    background: #fff;
    border: 2px solid #3C5990; /* PLUTA Blau 600 */
    width: 12px;
    height: 12px;
    border-radius: 50%;
    transition: all 0.2s;
  }

  .glide__bullet:hover {
    border-color: #283C60; /* PLUTA Blau 700 */
  }

  .glide__bullet--active {
    background: #3C5990; /* PLUTA Blau 600 */
    width: 24px;
    border-radius: 6px;
  }

  @media (max-width: 640px) {
    .glide__arrow {
      width: 40px;
      height: 40px;
      font-size: 1.25rem;
    }

    .glide__arrow--left {
      left: 0.75rem;
    }

    .glide__arrow--right {
      right: 0.75rem;
    }
  }
</style>
